rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Product images – public read, admin-only write
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null 
        && request.auth.token.email == 'willemvangreunen6@gmail.com';
    }

    // User avatars – owner read/write
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // General uploads – admin only
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null 
        && request.auth.token.email == 'willemvangreunen6@gmail.com';
    }
  }
}
